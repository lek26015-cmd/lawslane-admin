
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
        return isSignedIn() && (
          request.auth.uid == 'wS9w7ysNYUajNsBYZ6C7n2Afe9H3' || 
          request.auth.token.email == 'lek.26015@gmail.com' ||
          request.auth.token.role == 'admin' ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // Fallback: deny all access by default (each collection defines its own rules)
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /lawyerProfiles/{lawyerId} {
      allow read, list: if true;
      allow write: if isOwner(resource.data.userId) || isAdmin();
      allow update: if isOwner(resource.data.userId) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'reviewCount']));
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /chats/{chatId} {
      function isParticipant() {
        return isSignedIn() && request.auth.uid in resource.data.participants;
      }
      
      allow get, list: if isSignedIn(); // Broad access for now to fix dashbaord errors
      allow create: if isSignedIn();
      allow update: if isParticipant() || isAdmin();

      match /messages/{messageId} {
        function isChatParticipant() {
          return exists(/databases/$(database)/documents/chats/$(chatId)) &&
                 request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }

        allow get, list: if isChatParticipant() || isAdmin();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    match /articles/{articleId} {
        allow read: if true;
        allow write: if isAdmin();
    }
    
    match /ads/{adId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /appointments/{appointmentId} {
        allow create: if isSignedIn();
        allow read, list, update: if isOwner(resource.data.userId) || isOwner(resource.data.lawyerId) || isAdmin();
        allow list: if isSignedIn(); // Broad list for pending_payment verification
    }

    match /tickets/{ticketId} {
        allow create: if isSignedIn();
        allow read, list, update: if isOwner(resource.data.userId) || isAdmin();

        match /messages/{messageId} {
            allow read, list: if isAdmin() || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId);
            allow create: if isSignedIn();
        }
    }

    match /withdrawals/{withdrawalId} {
        allow create: if isSignedIn() && request.resource.data.lawyerId == request.auth.uid;
        allow read, list, update: if isOwner(resource.data.lawyerId) || isAdmin();
    }

    match /sme_inquiries/{inquiryId} {
        allow create: if true; // Public contact form
        allow read, update, delete: if isAdmin();
    }

    match /email_logs/{logId} {
        allow read, write: if isAdmin();
    }
    match /notifications/{notificationId} {
        // Allow creating notifications (e.g. from chat or admin actions)
        allow create: if isSignedIn();
        // Allow reading own notifications
        allow read: if isSignedIn() && (resource.data.recipient == request.auth.uid || resource.data.recipient == 'admin' && isAdmin());
        // Allow updating (marking as read) own notifications
        allow update: if isSignedIn() && (resource.data.recipient == request.auth.uid || resource.data.recipient == 'admin' && isAdmin());
    }
    match /landingPages/{pageId} {
        allow read: if true; // Public access for landing pages
        allow create, update, delete: if isAdmin();
    }
    
    match /verifiedLawyers/{lawyerId} {
        allow read: if true; // Public access for verification
        allow write: if isAdmin();
    }

    match /siteContent/{docId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /contractRequests/{requestId} {
        allow create: if true;
        allow read, update, delete: if isAdmin();
    }

    match /registrationRequests/{requestId} {
        allow create: if true;
        allow read, update, delete: if isAdmin();
    }

    match /smeRequests/{requestId} {
        allow create: if true;
        allow read, update, delete: if isAdmin();
    }

    match /legalForms/{formId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Allow admin to update everything
      // Allow public to update ONLY downloads count
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads']));
    }

    match /settings/{docId} {
        // Allow all authenticated users to read settings (for GP rate)
        allow read: if isSignedIn();
        // Only admins can write settings
        allow write: if isAdmin();
    }

    // student_exam_results removed (education module deleted)
    match /coupons/{couponId} {
      allow read, list: if true; // Temporarily loosened to troubleshoot
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']));
    }

    match /gpCoupons/{couponId} {
      allow read, list: if true; // Temporarily loosened to troubleshoot
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }
  }
}
