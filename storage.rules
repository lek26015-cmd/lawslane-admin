rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for profile images, articles, and public assets
    match /lawyerProfiles/{lawyerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == lawyerId || 
        request.auth.token.email == 'lek.26015@gmail.com');
    }

    match /articles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email == 'lek.26015@gmail.com';
    }

    match /ads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email == 'lek.26015@gmail.com';
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email == 'lek.26015@gmail.com';
    }

    // Chat attachments — only participants can write
    match /chats/{chatId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Contract files — authenticated users
    match /contracts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // User uploads (profile pics etc.)
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
